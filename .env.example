# Gemini AI Key
GEMINI_API_KEY=

# PesaPal Payment Configuration
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_ENV=sandbox # Options: sandbox, live
PESAPAL_IPN_URL= # Example: https://your-domain.com/api/pesapal/ipn
